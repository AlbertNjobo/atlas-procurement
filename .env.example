# Qwen Cloud (Alibaba Cloud DashScope) — required for the agent
QWEN_API_KEY=sk-your-qwen-api-key-here

# Resend — optional; email notifications for POs / approvals
RESEND_API_KEY=re-your-resend-api-key-here
RESEND_FROM_EMAIL=Procurely <notifications@procurely.dpdns.org>

# App
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
JSON_BODY_LIMIT=12mb

# API protection (recommended for public demos)
# When set, clients may also send x-api-key. Pair with VITE_API_SECRET in frontend builds.
API_SECRET=
# VITE_API_SECRET=   # only needed for Vite client builds that call APIs with the secret

# Optional: Firebase Admin for server-side ID token verification
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Rate limiting (requests per IP per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
